pipeline {
    agent any
    stages {
        stage('Cross Compile') {
            steps {
                sh 'echo "编译" > /tmp/current-stage.txt'
                sh 'make clean && make ARCH=arm64'
            }
        }
        stage('Unit Test') {
            steps {
                sh 'echo "单元测试" > /tmp/current-stage.txt'
                sh 'make test ARCH=arm64'
            }
        }
        stage('Verify Binary') {
            steps {
                sh 'echo "二进制验证" > /tmp/current-stage.txt'
                sh 'make verify ARCH=arm64'
            }
        }
        stage('Deploy to LubanCat') {
            steps {
                sh 'echo "部署运行" > /tmp/current-stage.txt'
                sh '''
                    scp -o StrictHostKeyChecking=no build/hello build/test_math_utils HUAWEI@10.0.0.2:E:/AI-helper/projects/cicd/workspace/deploy/artifacts/
                    ssh -o StrictHostKeyChecking=no HUAWEI@10.0.0.2 "powershell E:\\AI-helper\\projects\\cicd\\workspace\\deploy\\deploy-to-lubancat.ps1 -ArtifactPath E:\\AI-helper\\projects\\cicd\\workspace\\deploy\\artifacts\\hello -TargetIP 192.168.137.100"
                    ssh -o StrictHostKeyChecking=no HUAWEI@10.0.0.2 "powershell E:\\AI-helper\\projects\\cicd\\workspace\\deploy\\deploy-to-lubancat.ps1 -ArtifactPath E:\\AI-helper\\projects\\cicd\\workspace\\deploy\\artifacts\\test_math_utils -TargetIP 192.168.137.100"
                '''
            }
        }
    }
    post {
        success {
            sh '''
                { echo "SUCCESS"; echo "-"; git log -1 --format=%s; } | base64 -w0 > /tmp/build-msg.b64
                scp -o StrictHostKeyChecking=no /tmp/build-msg.b64 HUAWEI@10.0.0.2:E:/AI-helper/projects/cicd/workspace/deploy/artifacts/build-status.txt
                ssh -o StrictHostKeyChecking=no HUAWEI@10.0.0.2 "powershell E:\\AI-helper\\projects\\cicd\\workspace\\deploy\\notify-build.ps1"
            '''
        }
        failure {
            sh '''
                { echo "FAILED"; cat /tmp/current-stage.txt; git log -1 --format=%s; } | base64 -w0 > /tmp/build-msg.b64
                scp -o StrictHostKeyChecking=no /tmp/build-msg.b64 HUAWEI@10.0.0.2:E:/AI-helper/projects/cicd/workspace/deploy/artifacts/build-status.txt
                ssh -o StrictHostKeyChecking=no HUAWEI@10.0.0.2 "powershell E:\\AI-helper\\projects\\cicd\\workspace\\deploy\\notify-build.ps1"
            '''
        }
    }
 }
